{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability set for the main dictionary window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "sql:default",
    "sql:allow-execute",
    "fs:default",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-read-text-file",
    "fs:allow-remove",
    "fs:allow-write-text-file",
    "opener:default",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPDATA" },
        { "path": "$APPDATA/*" },
        { "path": "$APPDATA/**/*" }
      ]
    }
  ]
}
