{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Originalang Dictionary",
  "version": "0.1.0",
  "identifier": "com.originalang.dictionary",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Originalang Dictionary",
        "width": 1440,
        "height": 920,
        "minWidth": 1120,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "withGlobalTauri": false
  },
  "bundle": {
    "active": false
  }
}
